[gd_resource type="Resource" script_class="ResidentData" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/data/resident_data.gd" id="1_res"]
[ext_resource type="Script" path="res://scripts/data/require_plant_category.gd" id="2_req"]
[ext_resource type="Script" path="res://scripts/data/require_terrain.gd" id="3_req"]

[sub_resource type="Resource" id="Resource_req1"]
script = ExtResource("2_req")
category = 1
count = 1
mature_only = true
blooming = false

[sub_resource type="Resource" id="Resource_req2"]
script = ExtResource("3_req")
terrain_id = &"long_grass"
min_cells = 6

[resource]
script = ExtResource("1_res")
id = &"rabbit"
display_name = "Rabbit"
description = "A soft, twitchy-nosed nibbler that hides among the bushes and tall grass."
diary_hint = "Nibbles near bushes where the grass grows tall."
placeholder_color = Color(0.8, 0.78, 0.72, 1)
requirements = [SubResource("Resource_req1"), SubResource("Resource_req2")]
behaviors = 3
active_times = 7
active_seasons = 15
weather_needed = 0
xp_on_discovery = 25
